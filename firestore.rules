rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user can read everything
    // Writes are restricted by role
    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return request.auth.token.email in [
        'rogelio@ittelecom.com.mx',
        'arellanes@ittelecom.com.mx',
        'rogelioguerra@gmail.com'
      ];
    }

    function isAdmin() {
      return isAdminEmail() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin','superadmin'];
    }

    function isVendedor() {
      return isAdminEmail() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['vendedor','admin','superadmin'];
    }

    // Users collection
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && isAdmin();
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && isAdmin();

      match /proposals/{proposalId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && isVendedor();
      }

      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn()
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update: if isLoggedIn() && isAdmin();
        allow delete: if false;
      }
    }

    match /catalog/{id} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && isVendedor();
    }

    match /garantiaTemplates/{id} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && isAdmin();
    }

    match /kitTemplates/{id} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && isVendedor();
    }

    match /nomina/{id} {
      allow read, write: if isLoggedIn() && isAdmin();
    }

    match /cfdi/{id} {
      allow read, write: if isLoggedIn() && isAdmin();
    }

    match /equipoTRN/{id} {
      allow read: if isLoggedIn() && isAdmin();
      allow write: if isLoggedIn() && isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
